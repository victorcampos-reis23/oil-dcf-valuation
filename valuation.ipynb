"""
Oil Asset Valuation — DCF + LSTM Price Forecasting
====================================================
Author : Victor Hugo Campos Reis Alves
Purpose: Value an oil-producing asset by combining a Long Short-Term Memory
         (LSTM) neural network for Brent Crude price forecasting with a
         Discounted Cash Flow (DCF) model.  Scenario analysis produces
         P10 / P50 / P90 fair-value estimates.

Dependencies (install once):
    pip install yfinance numpy pandas scikit-learn tensorflow matplotlib seaborn
"""

import warnings
warnings.filterwarnings("ignore")

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.ticker as mticker
import seaborn as sns
import yfinance as yf

from sklearn.preprocessing import MinMaxScaler
from sklearn.metrics import mean_absolute_percentage_error

import tensorflow as tf
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import LSTM, Dense, Dropout
from tensorflow.keras.callbacks import EarlyStopping

# ─────────────────────────────────────────────
# 0. REPRODUCIBILITY
# ─────────────────────────────────────────────
SEED = 42
np.random.seed(SEED)
tf.random.set_seed(SEED)

# ─────────────────────────────────────────────
# 1. DATA COLLECTION
# ─────────────────────────────────────────────

def fetch_brent(start: str = "2010-01-01", end: str = "2024-12-31") -> pd.Series:
    """Download Brent Crude closing prices from Yahoo Finance."""
    print("📥  Downloading Brent Crude (BZ=F) from Yahoo Finance …")
    df = yf.download("BZ=F", start=start, end=end, progress=False)
    series = df["Close"].dropna()
    series.name = "Brent_USD"
    print(f"    {len(series)} daily observations  |  "
          f"{series.index[0].date()} → {series.index[-1].date()}")
    return series


# ─────────────────────────────────────────────
# 2. FEATURE ENGINEERING
# ─────────────────────────────────────────────

def build_features(series: pd.Series) -> pd.DataFrame:
    """Add technical / macro features to the raw price series."""
    df = series.to_frame()
    df["MA_20"]       = df["Brent_USD"].rolling(20).mean()
    df["MA_60"]       = df["Brent_USD"].rolling(60).mean()
    df["Volatility"]  = df["Brent_USD"].rolling(20).std()
    df["Return_1d"]   = df["Brent_USD"].pct_change(1)
    df["Return_5d"]   = df["Brent_USD"].pct_change(5)
    df["RSI"]         = _rsi(df["Brent_USD"])
    df.dropna(inplace=True)
    return df


def _rsi(prices: pd.Series, window: int = 14) -> pd.Series:
    delta  = prices.diff()
    gain   = delta.clip(lower=0).rolling(window).mean()
    loss   = (-delta.clip(upper=0)).rolling(window).mean()
    rs     = gain / loss
    return 100 - (100 / (1 + rs))


# ─────────────────────────────────────────────
# 3. LSTM DATASET PREPARATION
# ─────────────────────────────────────────────

LOOKBACK   = 60   # days of history fed into the LSTM
FEATURES   = ["Brent_USD", "MA_20", "MA_60", "Volatility",
              "Return_1d", "Return_5d", "RSI"]


def prepare_lstm_data(df: pd.DataFrame, test_ratio: float = 0.15):
    """Scale data and create (X, y) windows for the LSTM."""
    values = df[FEATURES].values
    scaler = MinMaxScaler()
    scaled = scaler.fit_transform(values)

    X, y = [], []
    for i in range(LOOKBACK, len(scaled)):
        X.append(scaled[i - LOOKBACK : i])
        y.append(scaled[i, 0])          # target = Brent_USD (column 0)

    X, y = np.array(X), np.array(y)

    split  = int(len(X) * (1 - test_ratio))
    X_train, X_test = X[:split], X[split:]
    y_train, y_test = y[:split], y[split:]

    return X_train, X_test, y_train, y_test, scaler, df.index[LOOKBACK:]


# ─────────────────────────────────────────────
# 4. LSTM MODEL
# ─────────────────────────────────────────────

def build_lstm(input_shape: tuple) -> Sequential:
    model = Sequential([
        LSTM(128, return_sequences=True, input_shape=input_shape),
        Dropout(0.2),
        LSTM(64, return_sequences=False),
        Dropout(0.2),
        Dense(32, activation="relu"),
        Dense(1)
    ])
    model.compile(optimizer="adam", loss="huber")
    return model


def train_lstm(model, X_train, y_train, epochs: int = 80, batch: int = 32):
    cb = EarlyStopping(monitor="val_loss", patience=10, restore_best_weights=True)
    print("\n🧠  Training LSTM …")
    history = model.fit(
        X_train, y_train,
        validation_split=0.1,
        epochs=epochs,
        batch_size=batch,
        callbacks=[cb],
        verbose=0,
    )
    print(f"    Stopped at epoch {len(history.history['loss'])}")
    return history


# ─────────────────────────────────────────────
# 5. PRICE FORECASTING  (12-month horizon)
# ─────────────────────────────────────────────

FORECAST_DAYS = 252          # ~12 months of trading days

# Scenario multipliers applied to the base LSTM forecast
SCENARIOS = {
    "P90 (Bull)":  1.15,
    "P50 (Base)":  1.00,
    "P10 (Bear)":  0.85,
}


def forecast_price(model, last_window: np.ndarray, scaler, n_days: int = FORECAST_DAYS):
    """Iteratively predict n_days ahead using the last known window."""
    window = last_window.copy()          # shape (LOOKBACK, n_features)
    preds  = []

    for _ in range(n_days):
        x    = window[np.newaxis, :, :]  # (1, LOOKBACK, n_features)
        pred = model.predict(x, verbose=0)[0, 0]
        preds.append(pred)

        # Roll window: drop oldest row, append new row
        new_row        = window[-1].copy()
        new_row[0]     = pred            # update Brent_USD (scaled)
        window         = np.vstack([window[1:], new_row])

    # Inverse-transform the price column only
    dummy = np.zeros((len(preds), scaler.n_features_in_))
    dummy[:, 0] = preds
    prices = scaler.inverse_transform(dummy)[:, 0]
    return prices


def inverse_price(scaled_vals, scaler):
    dummy = np.zeros((len(scaled_vals), scaler.n_features_in_))
    dummy[:, 0] = scaled_vals
    return scaler.inverse_transform(dummy)[:, 0]


# ─────────────────────────────────────────────
# 6. DCF MODEL
# ─────────────────────────────────────────────

# Asset assumptions (representative small oil producer)
PRODUCTION_BOPD   = 5_000        # barrels per day
OPEX_PER_BBL      = 20.0         # USD / barrel
ROYALTY_RATE      = 0.15         # 15 %
TAX_RATE          = 0.25         # 25 % corporate tax
CAPEX_ANNUAL      = 30_000_000   # USD — sustaining capex
WACC              = 0.12         # 12 % — typical E&P hurdle rate
TERMINAL_GROWTH   = 0.02         # 2 % perpetuity growth
PROJECTION_YEARS  = 10


def dcf_from_price_path(avg_prices: list) -> dict:
    """
    Build a DCF using projected annual average Brent prices.
    Returns NPV and year-by-year free cash flow.
    """
    fcfs   = []
    npv    = 0.0

    for t, price in enumerate(avg_prices, start=1):
        revenue    = PRODUCTION_BOPD * 365 * price
        royalties  = revenue * ROYALTY_RATE
        gross_prof = revenue - royalties - PRODUCTION_BOPD * 365 * OPEX_PER_BBL
        ebit       = gross_prof - CAPEX_ANNUAL
        nopat      = ebit * (1 - TAX_RATE)
        fcf        = nopat + CAPEX_ANNUAL        # add back non-cash capex
        fcfs.append(fcf)
        npv       += fcf / (1 + WACC) ** t

    # Terminal value (Gordon Growth)
    tv  = fcfs[-1] * (1 + TERMINAL_GROWTH) / (WACC - TERMINAL_GROWTH)
    npv += tv / (1 + WACC) ** PROJECTION_YEARS

    return {"npv": npv, "fcfs": fcfs, "terminal_value": tv}


def run_scenarios(base_forecast: np.ndarray) -> dict:
    """Apply bull / base / bear multipliers and compute DCF for each."""
    results = {}
    for label, mult in SCENARIOS.items():
        prices = base_forecast[:PROJECTION_YEARS * 252]
        annual = [
            prices[i * 252 : (i + 1) * 252].mean() * mult
            for i in range(PROJECTION_YEARS)
        ]
        results[label] = dcf_from_price_path(annual)
        results[label]["annual_prices"] = annual
    return results


# ─────────────────────────────────────────────
# 7. VISUALISATION
# ─────────────────────────────────────────────

PALETTE = {"P90 (Bull)": "#2ecc71", "P50 (Base)": "#3498db", "P10 (Bear)": "#e74c3c"}


def plot_all(series, df_feat, history, y_test_real, y_pred_real,
             test_dates, base_forecast, scenario_results, out_dir="outputs"):
    """Produce four publication-quality charts."""
    import os; os.makedirs(out_dir, exist_ok=True)

    sns.set_theme(style="darkgrid", palette="deep")
    plt.rcParams.update({"font.family": "DejaVu Sans", "axes.titlesize": 13})

    # ── 7a. Historical Brent price ──────────────────────────────────────────
    fig, ax = plt.subplots(figsize=(12, 4))
    ax.plot(series.index, series.values, color="#2980b9", lw=1.2)
    ax.set_title("Brent Crude Oil — Historical Price (USD/bbl)")
    ax.set_ylabel("USD / barrel")
    ax.yaxis.set_major_formatter(mticker.FormatStrFormatter("$%.0f"))
    fig.tight_layout()
    fig.savefig(f"{out_dir}/01_historical_price.png", dpi=150)
    plt.close()

    # ── 7b. LSTM training loss ──────────────────────────────────────────────
    fig, ax = plt.subplots(figsize=(8, 4))
    ax.plot(history.history["loss"],     label="Train loss", color="#2980b9")
    ax.plot(history.history["val_loss"], label="Val loss",   color="#e67e22")
    ax.set_title("LSTM Training — Huber Loss")
    ax.set_xlabel("Epoch"); ax.set_ylabel("Loss")
    ax.legend()
    fig.tight_layout()
    fig.savefig(f"{out_dir}/02_lstm_loss.png", dpi=150)
    plt.close()

    # ── 7c. Out-of-sample prediction vs actual ──────────────────────────────
    fig, ax = plt.subplots(figsize=(12, 4))
    ax.plot(test_dates, y_test_real, label="Actual",    color="#2c3e50", lw=1.5)
    ax.plot(test_dates, y_pred_real, label="LSTM Pred", color="#e74c3c", lw=1.2, ls="--")
    mape = mean_absolute_percentage_error(y_test_real, y_pred_real)
    ax.set_title(f"LSTM — Out-of-Sample Forecast  |  MAPE = {mape:.1%}")
    ax.set_ylabel("USD / barrel")
    ax.yaxis.set_major_formatter(mticker.FormatStrFormatter("$%.0f"))
    ax.legend()
    fig.tight_layout()
    fig.savefig(f"{out_dir}/03_lstm_vs_actual.png", dpi=150)
    plt.close()

    # ── 7d. DCF scenario waterfall ──────────────────────────────────────────
    labels = list(scenario_results.keys())
    npvs   = [scenario_results[l]["npv"] / 1e6 for l in labels]
    colors = [PALETTE[l] for l in labels]

    fig, axes = plt.subplots(1, 2, figsize=(14, 5))

    # Bar chart — NPV by scenario
    bars = axes[0].bar(labels, npvs, color=colors, edgecolor="white", width=0.5)
    axes[0].set_title("DCF Fair Value by Scenario (USD Million)")
    axes[0].set_ylabel("NPV  (USD MM)")
    axes[0].yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f"${x:,.0f}M"))
    for bar, val in zip(bars, npvs):
        axes[0].text(bar.get_x() + bar.get_width() / 2, bar.get_height() + 5,
                     f"${val:,.0f}M", ha="center", va="bottom", fontsize=10, fontweight="bold")

    # Line chart — annual price path per scenario
    years = list(range(1, PROJECTION_YEARS + 1))
    for label in labels:
        axes[1].plot(years, scenario_results[label]["annual_prices"],
                     label=label, color=PALETTE[label], lw=2, marker="o", ms=4)
    axes[1].set_title("Projected Annual Average Brent Price")
    axes[1].set_xlabel("Year")
    axes[1].set_ylabel("USD / barrel")
    axes[1].yaxis.set_major_formatter(mticker.FormatStrFormatter("$%.0f"))
    axes[1].legend()

    fig.suptitle("Oil Asset Valuation — DCF + LSTM Scenario Analysis", fontsize=14, fontweight="bold")
    fig.tight_layout()
    fig.savefig(f"{out_dir}/04_dcf_scenarios.png", dpi=150)
    plt.close()

    print(f"\n📊  Charts saved to ./{out_dir}/")


# ─────────────────────────────────────────────
# 8. MAIN PIPELINE
# ─────────────────────────────────────────────

def main():
    print("=" * 60)
    print("  OIL ASSET VALUATION — DCF + LSTM")
    print("=" * 60)

    # 1. Data
    series   = fetch_brent()
    df_feat  = build_features(series)

    # 2. Prepare LSTM data
    X_train, X_test, y_train, y_test, scaler, all_dates = prepare_lstm_data(df_feat)

    # 3. Build & train
    model   = build_lstm(input_shape=(LOOKBACK, len(FEATURES)))
    history = train_lstm(model, X_train, y_train)

    # 4. Evaluate on test set
    y_pred_scaled = model.predict(X_test, verbose=0).flatten()
    y_pred_real   = inverse_price(y_pred_scaled, scaler)
    y_test_real   = inverse_price(y_test,        scaler)
    test_dates    = all_dates[-len(y_test):]
    mape          = mean_absolute_percentage_error(y_test_real, y_pred_real)
    print(f"\n📈  Test MAPE : {mape:.2%}")

    # 5. Forecast 10 years ahead
    print(f"\n🔮  Forecasting {PROJECTION_YEARS} years ahead …")
    last_window    = X_test[-1]                        # last known window
    base_forecast  = forecast_price(model, last_window, scaler,
                                    n_days=PROJECTION_YEARS * 252)

    # 6. DCF scenarios
    scenario_results = run_scenarios(base_forecast)
    print("\n💰  DCF Results:")
    print(f"    {'Scenario':<20} {'NPV (USD MM)':>15}  {'Avg Price Yr1':>15}")
    print("    " + "-" * 52)
    for label, res in scenario_results.items():
        print(f"    {label:<20} ${res['npv']/1e6:>12,.1f}M  "
              f"${res['annual_prices'][0]:>12.1f}/bbl")

    # 7. Plots
    plot_all(series, df_feat, history,
             y_test_real, y_pred_real, test_dates,
             base_forecast, scenario_results)

    # 8. Save results
    summary = pd.DataFrame({
        "Scenario": list(scenario_results.keys()),
        "NPV_USD_MM": [r["npv"] / 1e6 for r in scenario_results.values()],
        "Avg_Price_Yr1_USD": [r["annual_prices"][0] for r in scenario_results.values()],
    })
    summary.to_csv("outputs/valuation_summary.csv", index=False)
    print("\n✅  valuation_summary.csv saved.")
    print("\n" + "=" * 60)
    print("  DONE — check the outputs/ folder for charts & CSV")
    print("=" * 60)


if __name__ == "__main__":
    main()
